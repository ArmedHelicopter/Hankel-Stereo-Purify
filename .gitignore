# ============================================================================
# Large Dataset Isolation - Audio Files (FLAC/100MB+)
# ============================================================================
# Raw audio data and processed output (typically 100MB+)
data/raw/**/*.flac
data/raw/**/*.wav
data/raw/**/*.mp3
data/raw/**/*.m4a
data/processed/**/*.flac
data/processed/**/*.wav

# General binary/media files exceeding 100MB
*.flac
*.wav
*.mp3
*.m4a

# Keep directory structure for documentation
!data/
!data/raw/
!data/processed/
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

