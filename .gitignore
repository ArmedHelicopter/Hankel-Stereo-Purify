# ============================================================================
# Large Dataset Isolation - Audio Files (FLAC/100MB+)
# ============================================================================
# Raw audio (data/raws/) and processed output (typically 100MB+)
data/raws/**/*.flac
data/raws/**/*.wav
data/raws/**/*.mp3
data/raws/**/*.m4a
data/processed/**/*.flac
data/processed/**/*.wav

# General binary/media files exceeding 100MB
*.flac
*.wav
*.mp3
*.m4a

# Keep directory structure for documentation
!data/
!data/raws/
!data/processed/
!data/.gitkeep
!data/raws/.gitkeep
!data/processed/.gitkeep

# ============================================================================
# Python Environment & Cache
# ============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.ruff_cache/
.mypy_cache/

# ============================================================================
# Jupyter Notebooks & IDE
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE & Editor
.vscode/*
!.vscode/settings.json
.idea/
.cursorrules
.cursor/
*.swp
*.swo
*~
.DS_Store
.env
.env.local

# ============================================================================
# Project-Specific Exclusions
# ============================================================================
# Temporary test files
*.tmp
*.log
.pytest_cache/
.coverage

# OS Files
Thumbs.db
# Windows / WSL: NTFS Zone.Identifier alternate stream sidecar
*Zone.Identifier
